{
  "schemaversion": "1.0",
  "id": "demo",
  "version": "1.0.0",

  "requirements": {
    "infrastructure": {
      "dmdp-box-version": "local-colima"
    },
    "tooling": {
      "tools-version": "demo",
      "compatibility-version": "1.0"
    }
  },

  "services": [
    {
      "name": "DEMO",
      "components": [
        {
          "name": "name-service",
          "version": "1.0.0",
          "deployment-method": "helm",
          "helm-chart": {
            "name": "charts/name-service",
            "version": "1.0.0"
          },
          "image": {
            "name": "name-service",
            "tag": "1.0.0",
            "digest": "sha256:USE_REAL_DIGEST_FROM_DOCKER_INSPECT"
          }
        },
        {
          "name": "greeting-service",
          "version": "1.0.0",
          "deployment-method": "helm",
          "helm-chart": {
            "name": "charts/greeting-service",
            "version": "1.0.0"
          },
          "image": {
            "name": "greeting-service",
            "tag": "1.0.0",
            "digest": "sha256:USE_REAL_DIGEST_FROM_DOCKER_INSPECT"
          }
        }
      ]
    }
  ]
}

